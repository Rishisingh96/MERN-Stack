<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    
    <!-- Header Section -->
    <section class="bg-white border-b">
      <div class="container mx-auto px-4 py-6">
        <h1 class="text-3xl font-bold text-gray-900"><%= editing ? "Edit" : "List"%> your place</h1>
        <p class="text-gray-600 mt-2">Start with the basics—your home's location and how many guests can stay.</p>
      </div>
    </section>

    <!-- Form Section -->
    <main class="container mx-auto px-4 py-8 max-w-4xl">
      <form action="/host/<%= editing ? "edit-home" : "add-home"%>" method="POST" enctype="multipart/form-data" class="space-y-8">
        <input type="hidden" name="id" value="<%= editing ? home._id : ''%>" />
        
        <!-- Property Name -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-xl font-semibold mb-4">Property name</h2>
          <div>
            <label for="houseName" class="block text-sm font-medium text-gray-700 mb-2">Property title</label>
            <input
              id="houseName"
              name="houseName"
              type="text"
              value="<%= editing ? home.houseName : ''%>"
              placeholder="Name your place"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition"
              required
            />
            <p class="mt-2 text-sm text-gray-500">
              Short titles work best. Have fun with it—you can always change it later.
            </p>
          </div>
        </div>

        <!-- Property Details -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-xl font-semibold mb-4">Property details</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Price -->
            <div>
              <label for="price" class="block text-sm font-medium text-gray-700 mb-2">Price per night</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-500">₹</span>
                <input
                  id="price"
                  name="price"
                  type="number"
                  value="<%= editing ? home.price : ''%>"
                  placeholder="0"
                  class="w-full pl-8 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition"
                  required
                />
              </div>
            </div>

            <!-- Rating -->
            <div>
              <label for="rating" class="block text-sm font-medium text-gray-700 mb-2">Rating</label>
              <div class="relative">
                <div class="absolute left-3 top-1/2 transform -translate-y-1/2 text-yellow-500">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                </div>
                <input
                  id="rating"
                  name="rating"
                  type="number"
                  min="1"
                  max="5"
                  step="0.1"
                  value="<%= editing ? home.rating : ''%>"
                  placeholder="5.0"
                  class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition"
                  required
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Location -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-xl font-semibold mb-4">Where's your place located?</h2>
          <div>
            <label for="location" class="block text-sm font-medium text-gray-700 mb-2">Address</label>
            <div class="relative">
              <div class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <input
                id="location"
                name="location"
                type="text"
                value="<%= editing ? home.location : ''%>"
                placeholder="Enter full address"
                class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition"
                required
              />
            </div>
          </div>
        </div>

        <!-- Photos -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-xl font-semibold mb-4">Photos</h2>
          <div class="space-y-4">
            <div>
              <label for="photo" class="block text-sm font-medium text-gray-700 mb-2">Property photo</label>
              <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-gray-400 transition cursor-pointer relative" id="dropZone">
                <input
                  id="photo"
                  name="photo"
                  type="file"
                  accept="image/jpg, image/jpeg, image/png, image/webp"
                  class="hidden"
                  onchange="handleFileSelect(this)"
                />
                <div class="flex flex-col items-center" id="uploadContent">
                  <svg class="w-12 h-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586 1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  <p class="text-lg font-medium text-gray-700" id="fileLabel">
                    <%= editing ? 'Change photo' : 'Click to upload or drag and drop' %>
                  </p>
                  <p class="text-sm text-gray-500 mt-1">
                    JPG, PNG, WebP (max. 10MB)
                  </p>
                </div>
                
                <!-- Image Preview -->
                <div id="imagePreview" class="hidden mt-4">
                  <div class="relative inline-block">
                    <img id="previewImg" src="" alt="Preview" class="w-32 h-32 object-cover rounded-lg">
                    <button type="button" onclick="clearImage()" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full p-1 hover:bg-red-600 transition">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
              
              <% if (editing && home.photo) { %>
                <div class="mt-4">
                  <p class="text-sm font-medium text-gray-700 mb-2">Current photo:</p>
                  <div class="relative inline-block">
                    <img src="<%= home.photo %>" alt="Current property" class="w-32 h-32 object-cover rounded-lg" id="currentImage">
                    <div class="mt-2 text-xs text-gray-500">
                      <%= home.photo.split('/').pop() %>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Description -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h2 class="text-xl font-semibold mb-4">Description</h2>
          <div>
            <label for="description" class="block text-sm font-medium text-gray-700 mb-2">About your place</label>
            <textarea
              id="description"
              name="description"
              rows="6"
              placeholder="Describe your property"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition resize-none"
              required
            ><%= editing ? home.description : ''%></textarea>
            <p class="mt-2 text-sm text-gray-500">
              Share what makes your place special.
            </p>
          </div>
        </div>

        <!-- Submit Section -->
        <div class="flex justify-between items-center bg-white rounded-xl p-6 shadow-sm">
          <button type="button" class="text-gray-600 hover:text-gray-800 transition font-medium">
            Cancel
          </button>
          <div class="flex gap-3">
            <button type="button" class="px-6 py-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition font-medium">
              Save draft
            </button>
            <button
              type="submit"
              class="px-8 py-3 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition font-medium"
            >
              <%= editing ? "Update home" : "Publish home" %>
            </button>
          </div>
        </div>
      </form>
    </main>

    <script>
      // File upload area click handler
      document.getElementById('dropZone').addEventListener('click', function() {
        document.getElementById('photo').click();
      });

      // Drag and drop functionality
      const dropZone = document.getElementById('dropZone');
      
      dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        this.classList.add('border-gray-400', 'bg-gray-50');
      });

      dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        this.classList.remove('border-gray-400', 'bg-gray-50');
      });

      dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        this.classList.remove('border-gray-400', 'bg-gray-50');
        
        const files = e.dataTransfer.files;
        if (files.length > 0) {
          handleFileSelect({ target: { files: files } });
        }
      });

      // File selection handler
      function handleFileSelect(input) {
        const file = input.target.files[0];
        
        if (file) {
          // Validate file type
          const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
          if (!validTypes.includes(file.type)) {
            alert('Please select a valid image file (JPG, PNG, or WebP)');
            return;
          }

          // Validate file size (10MB max)
          if (file.size > 10 * 1024 * 1024) {
            alert('File size must be less than 10MB');
            return;
          }

          // Update file label
          document.getElementById('fileLabel').textContent = file.name;
          
          // Show preview
          showImagePreview(file);
        }
      }

      // Show image preview
      function showImagePreview(file) {
        const reader = new FileReader();
        
        reader.onload = function(e) {
          const preview = document.getElementById('imagePreview');
          const previewImg = document.getElementById('previewImg');
          
          previewImg.src = e.target.result;
          preview.classList.remove('hidden');
          
          // Hide current image if editing
          const currentImage = document.getElementById('currentImage');
          if (currentImage) {
            currentImage.style.opacity = '0.5';
          }
        };
        
        reader.readAsDataURL(file);
      }

      // Clear selected image
      function clearImage() {
        document.getElementById('photo').value = '';
        document.getElementById('fileLabel').textContent = 'Click to upload or drag and drop';
        document.getElementById('imagePreview').classList.add('hidden');
        
        // Show current image if editing
        const currentImage = document.getElementById('currentImage');
        if (currentImage) {
          currentImage.style.opacity = '1';
        }
      }

      // Make functions global
      window.handleFileSelect = handleFileSelect;
      window.clearImage = clearImage;
    </script>
  </body>
</html>