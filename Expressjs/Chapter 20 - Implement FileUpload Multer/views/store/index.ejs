<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-rose-500 to-pink-600 text-white py-16">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Find your perfect stay</h1>
        <p class="text-xl mb-8 opacity-90">Discover amazing homes around the world</p>
        
        <!-- Search Bar -->
        <div class="max-w-4xl mx-auto bg-white rounded-full shadow-xl p-2 flex flex-col md:flex-row gap-2">
          <div class="flex-1 flex items-center px-4">
            <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <input type="text" placeholder="Where are you going?" class="w-full py-3 text-gray-800 outline-none">
          </div>
          <div class="flex items-center px-4 border-l border-gray-200">
            <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <input type="text" placeholder="Check in - Check out" class="py-3 text-gray-800 outline-none">
          </div>
          <div class="flex items-center px-4 border-l border-gray-200">
            <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <input type="text" placeholder="Guests" class="py-3 text-gray-800 outline-none w-20">
          </div>
          <button class="bg-rose-500 text-white px-8 py-3 rounded-full hover:bg-rose-600 transition flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            Search
          </button>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="container mx-auto px-4 py-8">
      <div class="flex gap-4 overflow-x-auto pb-4">
        <button class="flex flex-col items-center min-w-fit p-3 rounded-xl hover:bg-gray-100 transition">
          <div class="w-8 h-8 bg-rose-100 rounded-full flex items-center justify-center mb-2">
            <svg class="w-5 h-5 text-rose-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
          </div>
          <span class="text-sm font-medium">Amazing views</span>
        </button>
        <button class="flex flex-col items-center min-w-fit p-3 rounded-xl hover:bg-gray-100 transition">
          <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center mb-2">
            <svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 3.636a1 1 0 010 1.414 7 7 0 000 9.9 1 1 0 11-1.414 1.414 9 9 0 010-12.728 1 1 0 011.414 0zm9.9 0a1 1 0 011.414 0 9 9 0 010 12.728 1 1 0 11-1.414-1.414 7 7 0 000-9.9 1 1 0 010-1.414zM7.879 6.464a1 1 0 010 1.414 3 3 0 000 4.243 1 1 0 11-1.415 1.414 5 5 0 010-7.07 1 1 0 011.415 0zm4.242 0a1 1 0 011.415 0 5 5 0 010 7.072 1 1 0 01-1.415-1.415 3 3 0 000-4.242 1 1 0 010-1.415zM10 9a1 1 0 011 1v.01a1 1 0 11-2 0V10a1 1 0 011-1z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-sm font-medium">Beachfront</span>
        </button>
        <button class="flex flex-col items-center min-w-fit p-3 rounded-xl hover:bg-gray-100 transition">
          <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center mb-2">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
            </svg>
          </div>
          <span class="text-sm font-medium">Design</span>
        </button>
        <button class="flex flex-col items-center min-w-fit p-3 rounded-xl hover:bg-gray-100 transition">
          <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center mb-2">
            <svg class="w-5 h-5 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-sm font-medium">Romantic</span>
        </button>
        <button class="flex flex-col items-center min-w-fit p-3 rounded-xl hover:bg-gray-100 transition">
          <div class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center mb-2">
            <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3z"/>
            </svg>
          </div>
          <span class="text-sm font-medium">Cabins</span>
        </button>
      </div>
    </section>

    <!-- Homes Grid -->
    <main class="container mx-auto px-4 py-8">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Available homes</h2>
        <div class="flex gap-2">
          <button class="p-2 rounded-lg border hover:bg-gray-50 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <button class="p-2 rounded-lg border hover:bg-gray-50 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
            </svg>
          </button>
        </div>
      </div>

      <% if (!registeredHomes || registeredHomes.length === 0) { %>
        <div class="text-center py-16">
          <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">No homes available</h3>
          <p class="text-gray-600 mb-6">Be the first to list your property!</p>
          <a href="/host/add-home" class="bg-rose-500 text-white px-6 py-3 rounded-lg hover:bg-rose-600 transition">
            Add your home
          </a>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <% registeredHomes.forEach(home => { %>
            <div class="group cursor-pointer">
              <!-- Card Container -->
              <div class="relative rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
                <!-- Image Container -->
                <div class="relative aspect-square overflow-hidden">
                  <img 
                    src="<%= home.photo %>" 
                    alt="<%= home.houseName %>" 
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    onerror="this.src='https://via.placeholder.com/400x400?text=No+Image'"
                  >
                  
                  <!-- Heart Button -->
                  <button class="absolute top-3 right-3 p-2 bg-white/80 backdrop-blur-sm rounded-full hover:bg-white transition">
                    <svg class="w-5 h-5 text-gray-600 hover:text-red-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                  </button>
                  
                  <!-- Rating Badge -->
                  <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-lg flex items-center gap-1">
                    <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <span class="text-sm font-medium"><%= home.rating %></span>
                  </div>
                </div>
                
                <!-- Content -->
                <div class="p-4">
                  <!-- Title and Location -->
                  <div class="mb-2">
                    <h3 class="font-semibold text-gray-900 line-clamp-1"><%= home.houseName %></h3>
                    <p class="text-sm text-gray-600 flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      <%= home.location %>
                    </p>
                  </div>
                  
                  <!-- Price and Actions -->
                  <div class="flex justify-between items-end">
                    <div>
                      <p class="text-xl font-bold text-gray-900">₹<%= home.price %><span class="text-sm font-normal text-gray-600"> / night</span></p>
                    </div>
                    <div class="flex gap-2">
                      <a href="/homes/<%= home._id %>" class="bg-rose-500 text-white px-3 py-1.5 rounded-lg text-sm hover:bg-rose-600 transition">
                        View
                      </a>
                      <%- include('../partials/favourite', {home: home}) %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12 mt-16">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div>
            <h4 class="font-bold text-lg mb-4">About</h4>
            <ul class="space-y-2 text-gray-400">
              <li><a href="#" class="hover:text-white transition">How Airbnb works</a></li>
              <li><a href="#" class="hover:text-white transition">Newsroom</a></li>
              <li><a href="#" class="hover:text-white transition">Investors</a></li>
              <li><a href="#" class="hover:text-white transition">Airbnb Plus</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold text-lg mb-4">Community</h4>
            <ul class="space-y-2 text-gray-400">
              <li><a href="#" class="hover:text-white transition">Accessibility</a></li>
              <li><a href="#" class="hover:text-white transition">This is not real site</a></li>
              <li><a href="#" class="hover:text-white transition">Referrals</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold text-lg mb-4">Host</h4>
            <ul class="space-y-2 text-gray-400">
              <li><a href="/host/add-home" class="hover:text-white transition">Try hosting</a></li>
              <li><a href="#" class="hover:text-white transition">Protection</a></li>
              <li><a href="#" class="hover:text-white transition">Explore resources</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold text-lg mb-4">Support</h4>
            <ul class="space-y-2 text-gray-400">
              <li><a href="#" class="hover:text-white transition">Our COVID-19 Response</a></li>
              <li><a href="#" class="hover:text-white transition">Help Center</a></li>
              <li><a href="#" class="hover:text-white transition">Cancellation options</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
          <p>&copy; 2024 Airbnb Clone. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
function handleFavoriteClick(button) {
  const homeId = button.dataset.homeId;
  
  // Show login confirmation dialog
  const confirmed = confirm('Please login to add homes to your favorites. Would you like to login now?');
  
  if (confirmed) {
    // Redirect to login page with return URL
    window.location.href = '/login?returnUrl=' + encodeURIComponent(window.location.pathname);
  }
}

// Handle form submissions for logged-in users
document.querySelectorAll('.favorite-form').forEach(form => {
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const homeId = formData.get('id');
    
    fetch('/favourites', {
      method: 'POST',
      body: formData,
      headers: {
        'X-Requested-With': 'XMLHttpRequest'
      }
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        // Show success message
        showNotification('Added to favorites!', 'success');
        
        // Update button to show it's favorited
        const button = this.querySelector('button');
        button.classList.remove('bg-green-300', 'hover:bg-green-500');
        button.classList.add('bg-red-300', 'hover:bg-red-500');
        button.innerHTML = `
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
          </svg>
        `;
      }
    })
    .catch(error => {
      console.error('Error:', error);
      showNotification('Error adding to favorites', 'error');
    });
  });
});

// Notification function
function showNotification(message, type = 'info') {
  const notification = document.createElement('div');
  notification.className = `fixed top-4 right-4 p-4 rounded-lg shadow-lg z-50 transform transition-all duration-300 ${
    type === 'success' ? 'bg-green-500 text-white' :
    type === 'error' ? 'bg-red-500 text-white' :
    'bg-blue-500 text-white'
  }`;
  notification.textContent = message;
  
  document.body.appendChild(notification);
  
  // Animate in
  setTimeout(() => {
    notification.classList.add('translate-x-0');
  }, 100);
  
  // Remove after 3 seconds
  setTimeout(() => {
    notification.classList.add('translate-x-full', 'opacity-0');
    setTimeout(() => {
      document.body.removeChild(notification);
    }, 300);
  }, 3000);
}
</script>
