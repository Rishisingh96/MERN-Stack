<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    
    <!-- Header Section -->
    <section class="bg-white border-b">
      <div class="container mx-auto px-4 py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">Wishlists</h1>
            <p class="text-gray-600 mt-1">Your saved homes and experiences</p>
          </div>
          <div class="flex items-center gap-2">
            <button class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.707 0l-6.414-6.414A1 1 0 013 6.586V4z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4v16a1 1 0 001 1h16a1 1 0 001-1V4a1 1 0 00-1-1H3a1 1 0 00-1 1z"/>
              </svg>
            </button>
            <button class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
      <% if (!favouriteHomes || favouriteHomes.length === 0) { %>
        <!-- Empty State -->
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-rose-100 rounded-full mb-6">
            <svg class="w-10 h-10 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-semibold text-gray-900 mb-2">No favorites yet</h2>
          <p class="text-gray-600 mb-6 max-w-md mx-auto">
            As you search, tap the heart icon to save homes and experiences to your wishlist.
          </p>
          <a href="/" class="bg-rose-500 text-white px-6 py-3 rounded-lg hover:bg-rose-600 transition">
            Start exploring
          </a>
        </div>
      <% } else { %>
        <!-- Favorites Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <% favouriteHomes.forEach(home => { %>
            <div class="group cursor-pointer">
              <!-- Card Container -->
              <div class="relative rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
                <!-- Image Container -->
                <div class="relative aspect-square overflow-hidden">
                  <img 
                    src="<%= home.photo %>" 
                    alt="<%= home.houseName %>" 
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    onerror="this.src='https://via.placeholder.com/400x400?text=No+Image'"
                  >
                  
                  <!-- Heart Button (Filled for favorites) -->
                  <button class="absolute top-3 right-3 p-2 bg-white/80 backdrop-blur-sm rounded-full hover:bg-white transition">
                    <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M3.172 5.172a4 4 0 015.656 0L12 8.314l3.172-3.142a4 4 0 115.656 5.656L21 12l-5.172 5.172a4 4 0 01-5.656 0L12 15.686l-3.172 3.142a4 4 0 01-5.656 0L3 12l5.172-5.172a4 4 0 010-5.656z"/>
                    </svg>
                  </button>
                  
                  <!-- Rating Badge -->
                  <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-lg flex items-center gap-1">
                    <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <span class="text-sm font-medium"><%= home.rating %></span>
                  </div>
                </div>
                
                <!-- Content -->
                <div class="p-4">
                  <!-- Title and Location -->
                  <div class="mb-3">
                    <h3 class="font-semibold text-gray-900 line-clamp-1 mb-1"><%= home.houseName %></h3>
                    <p class="text-sm text-gray-600 flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      <%= home.location %>
                    </p>
                  </div>
                  
                  <!-- Price and Actions -->
                  <div class="flex justify-between items-end">
                    <div>
                      <p class="text-xl font-bold text-gray-900">₹<%= home.price %><span class="text-sm font-normal text-gray-600"> / night</span></p>
                    </div>
                    <div class="flex gap-2">
                      <a href="/homes/<%= home._id %>" class="bg-rose-500 text-white px-3 py-1.5 rounded-lg text-sm hover:bg-rose-600 transition">
                        View
                      </a>
                      <form action="/favourites/delete/<%= home._id %>" method="POST" class="inline">
                        <button type="submit" class="p-2 bg-gray-100 rounded-lg hover:bg-gray-200 transition" title="Remove from favorites">
                          <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                          </svg>
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Stats Section -->
        <div class="mt-12 bg-white rounded-xl p-6 shadow-sm">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-rose-100 rounded-full mb-3">
                <svg class="w-6 h-6 text-rose-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M3.172 5.172a4 4 0 015.656 0L12 8.314l3.172-3.142a4 4 0 115.656 5.656L21 12l-5.172 5.172a4 4 0 01-5.656 0L12 15.686l-3.172 3.142a4 4 0 01-5.656 0L3 12l5.172-5.172a4 4 0 010-5.656z"/>
                </svg>
              </div>
              <p class="text-2xl font-bold text-gray-900"><%= favouriteHomes.length %></p>
              <p class="text-sm text-gray-600">Saved homes</p>
            </div>
            <div class="text-center">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 rounded-full mb-3">
                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <p class="text-2xl font-bold text-gray-900"><%= favouriteHomes.reduce((sum, home) => sum + home.price, 0) %></p>
              <p class="text-sm text-gray-600">Avg. price/night</p>
            </div>
            <div class="text-center">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 rounded-full mb-3">
                <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <p class="text-2xl font-bold text-gray-900"><%= favouriteHomes.reduce((sum, home) => sum + (home.rating || 0), 0) / favouriteHomes.length %></p>
              <p class="text-sm text-gray-600">Avg. rating</p>
            </div>
          </div>
        </div>
      <% } %>
    </main>
  </body>
</html>
