<% if (errors && errors.length > 0) {%>
  <div style="background-color: #fee2e2; border: 1px solid #fca5a5; color: #dc2626; padding: 1rem; border-radius: 0.375rem; margin-bottom: 1rem;" role="alert">
    <strong style="font-weight: bold;">Error!</strong>
    <span style="display: block;">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </span>
    <span style="position: absolute; top: 0; bottom: 0; right: 0; padding: 0.75rem;">
      <i class="fas fa-times"></i>
    </span>
  </div>
<% } %>