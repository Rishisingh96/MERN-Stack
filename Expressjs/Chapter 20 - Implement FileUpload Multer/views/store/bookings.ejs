<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    
    <!-- Header Section -->
    <section class="bg-white border-b">
      <div class="container mx-auto px-4 py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">Trips</h1>
            <p class="text-gray-600 mt-1">Upcoming and past reservations</p>
          </div>
          <div class="flex items-center gap-2">
            <button class="px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition">
              Find new places
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
      <!-- Tabs -->
      <div class="border-b border-gray-200 mb-8">
        <nav class="-mb-px flex space-x-8">
          <button class="py-4 px-1 border-b-2 border-rose-500 font-medium text-rose-600">
            Upcoming
          </button>
          <button class="py-4 px-1 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300 transition">
            Past
          </button>
          <button class="py-4 px-1 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300 transition">
            Cancelled
          </button>
        </nav>
      </div>

      <!-- Bookings Grid -->
      <div class="space-y-6">
        <!-- Sample Booking Card 1 - Upcoming -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-3">
            <!-- Image Section -->
            <div class="md:col-span-1 relative">
              <img src="https://via.placeholder.com/400x300?text=Beautiful+Home" alt="Property" class="w-full h-64 md:h-full object-cover">
              <div class="absolute top-4 left-4">
                <span class="bg-green-500 text-white px-3 py-1 rounded-full text-sm font-medium">
                  Confirmed
                </span>
              </div>
            </div>
            
            <!-- Details Section -->
            <div class="md:col-span-2 p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">Cozy Forest Retreat</h3>
                  <p class="text-gray-600 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Manali, Himachal Pradesh
                  </p>
                </div>
                <div class="text-right">
                  <p class="text-2xl font-bold text-gray-900">₹3,500</p>
                  <p class="text-sm text-gray-600">per night</p>
                </div>
              </div>
              
              <!-- Booking Details -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-medium text-gray-900 mb-2">Dates</h4>
                  <div class="space-y-1">
                    <p class="text-sm text-gray-600">Check-in: <span class="font-medium text-gray-900">Mar 15, 2024</span></p>
                    <p class="text-sm text-gray-600">Check-out: <span class="font-medium text-gray-900">Mar 18, 2024</span></p>
                  </div>
                </div>
                
                <div>
                  <h4 class="font-medium text-gray-900 mb-2">Guests</h4>
                  <div class="space-y-1">
                    <p class="text-sm text-gray-600">Adults: <span class="font-medium text-gray-900">2</span></p>
                    <p class="text-sm text-gray-600">Children: <span class="font-medium text-gray-900">1</span></p>
                  </div>
                </div>
              </div>
              
              <!-- Actions -->
              <div class="flex gap-3 mt-6 pt-4 border-t border-gray-200">
                <button class="flex-1 bg-rose-500 text-white py-2 rounded-lg hover:bg-rose-600 transition font-medium">
                  View details
                </button>
                <button class="flex-1 border border-gray-300 py-2 rounded-lg hover:bg-gray-50 transition font-medium">
                  Message host
                </button>
                <button class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zM12 13a1 1 0 110-2 1 1 0 010 2zM12 20a1 1 0 110-2 1 1 0 010 2z"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Sample Booking Card 2 - Upcoming -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-3">
            <!-- Image Section -->
            <div class="md:col-span-1 relative">
              <img src="https://via.placeholder.com/400x300?text=Beach+House" alt="Property" class="w-full h-64 md:h-full object-cover">
              <div class="absolute top-4 left-4">
                <span class="bg-yellow-500 text-white px-3 py-1 rounded-full text-sm font-medium">
                  Pending
                </span>
              </div>
            </div>
            
            <!-- Details Section -->
            <div class="md:col-span-2 p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">Beach Paradise Villa</h3>
                  <p class="text-gray-600 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Goa, India
                  </p>
                </div>
                <div class="text-right">
                  <p class="text-2xl font-bold text-gray-900">₹5,200</p>
                  <p class="text-sm text-gray-600">per night</p>
                </div>
              </div>
              
              <!-- Booking Details -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-medium text-gray-900 mb-2">Dates</h4>
                  <div class="space-y-1">
                    <p class="text-sm text-gray-600">Check-in: <span class="font-medium text-gray-900">Apr 2, 2024</span></p>
                    <p class="text-sm text-gray-600">Check-out: <span class="font-medium text-gray-900">Apr 5, 2024</span></p>
                  </div>
                </div>
                
                <div>
                  <h4 class="font-medium text-gray-900 mb-2">Guests</h4>
                  <div class="space-y-1">
                    <p class="text-sm text-gray-600">Adults: <span class="font-medium text-gray-900">4</span></p>
                    <p class="text-sm text-gray-600">Children: <span class="font-medium text-gray-900">2</span></p>
                  </div>
                </div>
              </div>
              
              <!-- Actions -->
              <div class="flex gap-3 mt-6 pt-4 border-t border-gray-200">
                <button class="flex-1 bg-rose-500 text-white py-2 rounded-lg hover:bg-rose-600 transition font-medium">
                  View details
                </button>
                <button class="flex-1 border border-gray-300 py-2 rounded-lg hover:bg-gray-50 transition font-medium">
                  Message host
                </button>
                <button class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zM12 13a1 1 0 110-2 1 1 0 010 2zM12 20a1 1 0 110-2 1 1 0 010 2z"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Sample Booking Card 3 - Past -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden opacity-75">
          <div class="grid grid-cols-1 md:grid-cols-3">
            <!-- Image Section -->
            <div class="md:col-span-1 relative">
              <img src="https://via.placeholder.com/400x300?text=Mountain+Cabin" alt="Property" class="w-full h-64 md:h-full object-cover">
              <div class="absolute top-4 left-4">
                <span class="bg-gray-500 text-white px-3 py-1 rounded-full text-sm font-medium">
                  Completed
                </span>
              </div>
            </div>
            
            <!-- Details Section -->
            <div class="md:col-span-2 p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">Mountain View Cabin</h3>
                  <p class="text-gray-600 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Shimla, Himachal Pradesh
                  </p>
                </div>
                <div class="text-right">
                  <p class="text-2xl font-bold text-gray-900">₹2,800</p>
                  <p class="text-sm text-gray-600">per night</p>
                </div>
              </div>
              
              <!-- Booking Details -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-medium text-gray-900 mb-2">Dates</h4>
                  <div class="space-y-1">
                    <p class="text-sm text-gray-600">Check-in: <span class="font-medium text-gray-900">Feb 10, 2024</span></p>
                    <p class="text-sm text-gray-600">Check-out: <span class="font-medium text-gray-900">Feb 12, 2024</span></p>
                  </div>
                </div>
                
                <div>
                  <h4 class="font-medium text-gray-900 mb-2">Guests</h4>
                  <div class="space-y-1">
                    <p class="text-sm text-gray-600">Adults: <span class="font-medium text-gray-900">2</span></p>
                    <p class="text-sm text-gray-600">Children: <span class="font-medium text-gray-900">0</span></p>
                  </div>
                </div>
              </div>
              
              <!-- Actions -->
              <div class="flex gap-3 mt-6 pt-4 border-t border-gray-200">
                <button class="flex-1 bg-rose-500 text-white py-2 rounded-lg hover:bg-rose-600 transition font-medium">
                  Book again
                </button>
                <button class="flex-1 border border-gray-300 py-2 rounded-lg hover:bg-gray-50 transition font-medium">
                  Leave review
                </button>
                <button class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zM12 13a1 1 0 110-2 1 1 0 010 2zM12 20a1 1 0 110-2 1 1 0 010 2z"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Empty State (if no bookings) -->
      <% if (!bookings || bookings.length === 0) { %>
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-blue-100 rounded-full mb-6">
            <svg class="w-10 h-10 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-semibold text-gray-900 mb-2">No trips yet</h2>
          <p class="text-gray-600 mb-6 max-w-md mx-auto">
            Ready for your next adventure? Start exploring homes and plan your perfect trip.
          </p>
          <a href="/" class="bg-rose-500 text-white px-6 py-3 rounded-lg hover:bg-rose-600 transition">
            Start exploring
          </a>
        </div>
      <% } %>
    </main>
  </body>
</html>
